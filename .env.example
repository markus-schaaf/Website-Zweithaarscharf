# Vorlage für Produktions-Umgebungsvariablen.
# Werte setzen und als Umgebungsvariablen des Servers hinterlegen (nicht committen!).

# Sicherheit — Pflicht in Produktion
DJANGO_SECRET_KEY=hier-einen-langen-zufaelligen-schluessel-eintragen
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=www.example.de,example.de

# E-Mail-Versand (SMTP-Zugangsdaten vom Hoster)
DJANGO_EMAIL_HOST=smtp.example.de
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=info@zweithaarschaaf.de
DJANGO_EMAIL_HOST_PASSWORD=geheim
DJANGO_EMAIL_USE_TLS=1
DJANGO_DEFAULT_FROM_EMAIL=info@zweithaarschaaf.de

# Empfänger für Kontakt-/Terminanfragen
ZS_CONTACT_EMAIL=info@zweithaarschaaf.de

# 3D-Produktvorschau (siehe README.md)
MESHY_API_KEY=
IMAGE3D_PROVIDER=meshy
# Produktion: 0 setzen und Redis + Celery-Worker betreiben
CELERY_TASK_ALWAYS_EAGER=1
CELERY_BROKER_URL=redis://localhost:6379/0
